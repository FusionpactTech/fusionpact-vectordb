    "mcp": "node bin/cli.js mcp",
    "bench": "node bin/cli.js bench",
    "test": "node --test test/**/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage test/**/*.test.js",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "vector-database", "retrieval-engine", "hybrid-retrieval", "reasoning-rag",
    "vectorless-rag", "tree-index", "hnsw", "agent-memory", "mcp-server",
